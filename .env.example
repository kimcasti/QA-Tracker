# Public backend URL used at build time by the frontend.
VITE_API_URL=http://localhost:1337

# Optional Gemini / AI features.
VITE_GEMINI_API_KEY=
VITE_GROQ_API_KEY=

# Optional Cloudinary config for evidence uploads from clipboard/manual upload.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Optional business WhatsApp used in the freemium upgrade CTA.
VITE_UPGRADE_WHATSAPP_PHONE=

# Leave disabled unless you explicitly want service-auth from the frontend build.
VITE_USE_SERVICE_AUTH=false
VITE_API_IDENTIFIER=
VITE_API_PASSWORD=
